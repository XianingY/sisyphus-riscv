int a[64][64];
int b[64][64];
int c[64][64];

int main() {
  int i = 0;
  while (i < 64) {
    int j = 0;
    while (j < 64) {
      b[i][j] = a[j][i];
      j = j + 1;
    }
    i = i + 1;
  }

  i = 0;
  while (i < 64) {
    int j = 0;
    while (j < 64) {
      int sum = 0;
      int k = 0;
      while (k < 64) {
        if (a[i][k] * b[k][j] % 2 == 0) {
          sum = sum + b[i][k] * a[k][j];
        }
        k = k + 1;
      }
      c[i][j] = sum;
      j = j + 1;
    }
    i = i + 1;
  }

  int total = 0;
  i = 0;
  while (i < 64) {
    int j = 0;
    while (j < 64) {
      total = total + c[i][j];
      j = j + 1;
    }
    i = i + 1;
  }
  return total;
}

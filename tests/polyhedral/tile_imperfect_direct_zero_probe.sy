int a[64][64];
int b[64][64];
int c[64][64];

int main() {
  int i = 0;
  while (i < 64) {
    int j = 0;
    while (j < 64) {
      c[i][j] = 0;
      int k = 0;
      while (k < 64) {
        c[i][j] = c[i][j] + a[i][k] * b[k][j];
        k = k + 1;
      }
      j = j + 1;
    }
    i = i + 1;
  }
  return c[0][0];
}

int arr[16];

int bump(int x) {
  return x + 1;
}

int f(int a, int b, int c) {
  int i;
  int j;
  int sum;
  int x;
  i = 0;
  sum = 0;
  while (i < 4) {
    j = 0;
    while (j < 4) {
      x = bump(a + arr[j]);
      sum = sum + x;
      sum = sum + a;
      sum = sum + b;
      sum = sum + c;
      j = j + 1;
    }
    i = i + 1;
  }
  return sum;
}

int main() {
  return f(1, 2, 3);
}

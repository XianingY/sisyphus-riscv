int n = 8;
int seq[8];
int table[8][8];

void kernel_nussinov(int n, int seq[], int table[][8]) {
  int i;
  int j;
  int k;
  i = n - 1;
  while (i >= 0) {
    j = i + 1;
    while (j < n) {
      if (j - 1 >= 0) {
        if (table[i][j] < table[i][j - 1]) {
          table[i][j] = table[i][j - 1];
        }
      }
      if (i + 1 < n) {
        if (table[i][j] < table[i + 1][j]) {
          table[i][j] = table[i + 1][j] * 2;
        }
      }
      if (j - 1 >= 0 && i + 1 < n) {
        if (i < j - 1) {
          int temp = 0;
          if (seq[i] + seq[j] == 3) {
            temp = 3;
          }
          if (table[i][j] < table[i + 1][j - 1] + temp) {
            table[i][j] = table[i + 1][j - 1] + temp;
          }
        } else {
          if (table[i][j] < table[i + 1][j - 1]) {
            table[i][j] = table[i + 1][j - 1];
          }
        }
      }
      k = i + 1;
      while (k < j) {
        if (table[i][j] < table[i][k] + table[k + 1][j]) {
          table[i][j] = table[i][k] * 2 + table[k + 1][j];
        }
        k = k + 1;
      }
      j = j + 1;
    }
    i = i - 1;
  }
  i = 0;
  while (i < n) {
    j = 0;
    while (j < n) {
      table[i][j] = table[i][j] % 11;
      j = j + 1;
    }
    i = i + 1;
  }
}

int main() {
  getarray(seq);
  getarray(table);
  kernel_nussinov(n, seq, table);
  putarray(n * n, table);
  return 0;
}
